{
  "name": "paralegal-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first email summarization for law firms",
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "start": "cd apps/landing && pnpm run start",
    "start:prod": "pnpm run start",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "test": "pnpm -r --filter=@paralegal-ai/schemas --filter=@paralegal-ai/bridge run test",
    "test:all": "pnpm -r run test",
    "test:policy": "pnpm -r run test:policy",
    "test:integration": "pnpm -r run test:integration",
    "test:e2e": "pnpm -r run test:e2e",
    "doctor": "node scripts/doctor.mjs",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^20.0.0"
    }
  },
  "packageManager": "pnpm@9.0.0"
}