# Paralegal AI Environment Variables
# Copy this file to .env and update values as needed

# Next.js Landing Page
NEXT_PUBLIC_API_BASE_URL=http://localhost:8002

# Bridge Service (NestJS)
NODE_ENV=development
PORT=8002
CONNECTED_LLM_ENABLED=false
CONNECTED_LLM_URL=http://connected-llm:8002

# Summarizer Service (Python)
DEBUG=true
PRIVATE_LLM_URL=http://private-llm:8000/v1

# LLM Configuration (for docker-compose.llm.yml)
LLM_PRIVATE_BASE_URL=http://localhost:8001/v1
LLM_PRIVATE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
LLM_CONNECTED_ENABLED=false
LLM_CONNECTED_BASE_URL=http://localhost:8010/v1

# External API Keys (optional - for connected LLM only)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Server Configuration
HOSTNAME=0.0.0.0
KEEP_ALIVE_TIMEOUT=5000

# Docker/Production
# NODE_ENV=production
# DEBUG=false
# PORT=3000

# Optional: Docker override for different ports
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8002